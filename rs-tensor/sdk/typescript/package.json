{
  "name": "rs-tensor-mcp",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the rs-tensor MCP server (tensors, MLP training, autograd, LLaMA)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "example:xor": "tsx examples/train-xor.mts",
    "test:smoke": "tsx scripts/smoke-test.mts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "tensor",
    "ml",
    "rs-tensor"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
